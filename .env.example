# ─────────────────────────────────────────────────────────────────────────
# ccbot configuration.
#
# Copy this file to `.env` (in the repo root or in $CCBOT_DIR, default
# ~/.ccbot/) and fill in the REQUIRED section. Everything else has a sane
# default — you only set an optional var to change behaviour or turn a
# feature on. `.env` is gitignored; never commit real tokens.
#
# Only two variables are required to run. The rest of the file is optional
# and grouped: Core → Display → Voice/TTS → Reactions → Docker agents →
# Notifications → Server-specific (leave blank unless you run this exact
# infra). See SETUP.md for a first-run walkthrough.
# ─────────────────────────────────────────────────────────────────────────


# ══ REQUIRED ═════════════════════════════════════════════════════════════

# Bot token from @BotFather (https://t.me/BotFather).
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram numeric user IDs allowed to use the bot.
# This is a single-user / small-trusted-group bot: only these IDs are served.
# Find yours via @userinfobot.
ALLOWED_USERS=123456789


# ══ CORE (optional — sane defaults) ══════════════════════════════════════

# Config + state directory. `.env` is also loaded from here.
# NOTE: unlike other variables here, CCBOT_DIR is best EXPORTED in your shell
# profile rather than set only in .env: the session-tracking hook runs inside
# Claude Code panes and never reads .env. The bot forwards a .env-only value
# into its own tmux session, but a `claude` started outside that session
# would still use the default ~/.ccbot.
# CCBOT_DIR=~/.ccbot

# Tmux session that holds the bot's own window + all agent windows.
# TMUX_SESSION_NAME=ccbot

# Command launched in each new agent window. On a headless VPS with no
# interactive terminal to approve permissions you may want:
#   CLAUDE_COMMAND=claude --dangerously-skip-permissions
# Any other claude flags ride along here too — e.g. add --remote-control
# to auto-enable Claude Code's phone remote control (/rc) in every session;
# omit it (the default) if you don't want RC started for you.
# CLAUDE_COMMAND=claude

# Seconds between JSONL transcript polls.
# MONITOR_POLL_INTERVAL=2.0

# UI language for the bot's own chrome (buttons, /status, messages): ru | en.
# A per-install /lang switch (persisted in state.json) overrides this; this
# is only the boot default a fresh install starts with.
# CCBOT_DEFAULT_LANG=en

# Log level (DEBUG|INFO|WARNING|ERROR).
# CCBOT_LOG_LEVEL=INFO

# Point the monitor at a non-default Claude projects dir (for Claude variants).
# Priority: CCBOT_CLAUDE_PROJECTS_PATH > CLAUDE_CONFIG_DIR/projects > default.
# CCBOT_CLAUDE_PROJECTS_PATH=
# CLAUDE_CONFIG_DIR=

# Roots (under $HOME) scanned when a topic name is auto-bound to a directory:
# a topic "foo" binds to ~/<root>/foo, first root wins. Comma-separated.
# CCBOT_TOPIC_DIR_ROOTS=projects,agents

# systemd --user units to surface in /status (comma-separated). Empty = the
# "services" block is omitted.
# CCBOT_STATUS_SERVICES=

# Native rich replies (Telegram Bot API 10.2, ON by default): when a reply
# would otherwise degrade — a table rendered to a PNG, long code shipped as a
# file, or text split into [1/N] pages — the bot sends ONE native rich
# message instead (real tables, headings, highlighted code, 32k char limit),
# falling back to the classic delivery on any failure. Set =false to disable.
# CCBOT_RICH_MESSAGES=true
# How tables in agent replies are delivered: "rich" (default) = native
# Telegram tables (copyable, theme-aware; falls back to a screenshot if
# Telegram rejects the send), "image" = bordered-grid screenshots always.
# Runtime toggle: /tables (persisted, overrides this boot default).
# CCBOT_TABLE_STYLE=rich


# ══ AGENT RUNTIMES — Codex as a second CLI (optional) ════════════════════
# Besides Claude Code, a topic's window can run OpenAI's Codex CLI. Nothing
# to enable: if the `codex` binary is on PATH, the session picker grows a
# Codex tab (and the 🌳 worktree flow a Codex option) automatically; without
# it the tab never shows. Each topic remembers its runtime and comes back on
# the same CLI after a window death / tmux restart.
# Known Codex limits: no context-limit alerts; inbound documents (not images)
# need a working sandbox or the bypass below; one Codex window per directory
# (its transcript is matched by cwd, two would cross-talk — the bot refuses
# the second).

# Runtime for new windows where nothing was chosen explicitly: the initially
# active picker tab and never-bound auto-bind topics. claude | codex.
# Ignored (falls back to claude) when that CLI isn't installed.
# CCBOT_DEFAULT_RUNTIME=claude

# Codex CLI command (flags ride along, like CLAUDE_COMMAND).
# CODEX_COMMAND=codex

# Root of Codex's rollout transcripts, if CODEX_HOME is non-default.
# CODEX_SESSIONS_PATH=~/.codex/sessions

# LAST RESORT: launch codex with --dangerously-bypass-approvals-and-sandbox.
# Only for hosts where codex's own sandbox cannot initialize (e.g. Ubuntu
# 24.04 AppArmor vs codex's bundled bwrap — the PROPER fix is
# `apt install bubblewrap`) AND the environment is already externally
# sandboxed. This is `danger-full-access`; OpenAI does not recommend it on
# personal machines.
# CODEX_BYPASS_SANDBOX=false


# ══ DISPLAY toggles (all OFF by default — set =true to opt in) ═══════════
# The default chat shows only the agent's text replies + interactive prompts.
# Each toggle below adds more to the chat; leave them off for a clean feed.

# Echo 👤 your own messages back into the topic.
# CCBOT_SHOW_USER_MESSAGES=true
# Show thinking blocks.
# CCBOT_SHOW_THINKING=true
# Show hidden (dot) directories in the directory browser.
# CCBOT_SHOW_HIDDEN_DIRS=true
# Sandbox the directory browser to one subtree: browsing starts here and
# «..» never goes above it. Unset = legacy behavior (start at $HOME, up to /).
# Useful on shared or privacy-sensitive hosts.
# CCBOT_BROWSE_ROOT=~/projects


# ══ VOICE — transcription & TTS (optional; each key-gated) ═══════════════
# Inbound voice messages are transcribed; with a TTS key the bot can also
# reply with voice (/voice per-topic toggle). All disabled if no keys set.

# Transcription: Deepgram (preferred) → OpenAI (fallback).
# DEEPGRAM_API_KEY=
# DEEPGRAM_LANGUAGE=            # empty = auto-detect; or a BCP-47 code e.g. ru
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# TTS provider policy: auto = Gemini → ElevenLabs → OpenAI with fallback;
# or pin one (gemini|elevenlabs|openai) so the voice never changes mid-chat.
# TTS_PROVIDER=auto

# Gemini TTS (needs ffmpeg for PCM→OGG).
# GEMINI_API_KEY=
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# GEMINI_TTS_VOICE=Sulafat
# GEMINI_TTS_TEMPERATURE=1.0
# BCP-47 code to pin the spoken language (e.g. ru-RU); empty = auto-detect.
# GEMINI_TTS_LANGUAGE=
# GEMINI_TTS_STYLE_PREFIX=Speak warmly like you're chatting with a close friend, at a brisk natural pace:

# ElevenLabs TTS.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2

# OpenAI TTS (uses OPENAI_API_KEY above).
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_MODEL=tts-1


# ══ REACTIONS (optional) ═════════════════════════════════════════════════

# 👍 on an agent message = "yes, go ahead" (Enter on a prompt / «да» to idle).
# REACTION_CONFIRM_ENABLED=true
# REACTION_CONFIRM_EMOJI=👍
# REACTION_CONFIRM_DEBOUNCE_SEC=2.5

# Bot puts 👀 on your message once the agent takes it into context (a read
# receipt). ON by default; runtime toggle is /react. Set false to disable —
# it pushes a reaction notification per message (or mute reactions client-side).
# CCBOT_REACTION_ACK=true

# ══ TASK PINNING ═════════════════════════════════════════════════════════

# A big user message (≥ CCBOT_PIN_MIN_CHARS chars) sent to an IDLE agent is
# pinned in its topic — the pinned list becomes the topic's task history.
# Short replies and mid-turn follow-ups never pin. ON by default; /pin
# toggles it per topic. Needs the bot to have the "Pin messages" and
# "Delete messages" admin rights (the latter removes the bot's own «pinned
# a message» service lines); without them it degrades to log warnings.
# CCBOT_PIN_DEFAULT=true
# CCBOT_PIN_MIN_CHARS=150


# Transparent session resume on auto-bind. OFF by default (the interactive
# session picker is the norm). When true, a topic auto-binding to a folder that
# already has Claude history silently continues the MOST RECENT session instead
# of showing a picker — for non-technical users whose agent sessions would
# otherwise restart fresh after a container/tmux restart dropped the window.
# CCBOT_AUTO_RESUME_AGENTS=false


# ══ DOCKER AGENTS (optional) ═════════════════════════════════════════════
# Route a topic to a Claude Code instance inside a container instead of a
# host tmux window. Off by default — leave disabled for a plain tmux setup.

# DOCKER_AGENTS_ENABLED=false
# DOCKER_AGENTS=assistant,scout
# Per-agent paths default to ~/agents/<name> (workspace) and
# ~/.local/share/<name>/... — override any per agent (name upper-cased):
# DOCKER_AGENT_ASSISTANT_CONTAINER=assistant
# DOCKER_AGENT_ASSISTANT_WORKSPACE=~/agents/assistant
# DOCKER_AGENT_ASSISTANT_CLAUDE_HOME=~/.local/share/assistant/claude-home
# DOCKER_AGENT_ASSISTANT_IPC=~/.local/share/assistant/ipc
# DOCKER_AGENT_ASSISTANT_SESSION_MAP=~/.local/share/assistant/session-map.json
# DOCKER_AGENT_ASSISTANT_VNC_URL=vnc://<tailscale-ip>:5900


# ══ NOTIFICATIONS & LIVE DASHBOARD (optional) ════════════════════════════
# NOTIFICATIONS_CHAT_ID: a supergroup for cross-cutting notices (core uses it
# for voice-budget alerts; plugins for their pushes). The LIVE_DASHBOARD_*
# vars are consumed by the `fleet` plugin (docker-agent browser screenshots +
# the "up right now" board) and do nothing without it.

# NOTIFICATIONS_CHAT_ID=            # numeric chat_id of the supergroup
# LIVE_DASHBOARD_THREAD_ID=         # thread_id of a hand-made "Live" topic
# LIVE_DASHBOARD_TAILSCALE_URL=     # optional deep link shown above VNC


# ─────────────────────────────────────────────────────────────────────────
# ══ SERVER-SPECIFIC (advanced) ═══════════════════════════════════════════
# The rest of the file wires ccbot into extra host infrastructure: optional
# add-on plugins, a localhost task-injection socket, and a `preview` CLI +
# Caddy fleet + rclone mounts. On any normal deployment you LEAVE THIS ENTIRE
# SECTION BLANK — each block is disabled unless its token/flag is set. It's
# documented only so a reference deployment is reproducible.
# ─────────────────────────────────────────────────────────────────────────

# ── CCBOT_PLUGINS — optional add-on packages (mail bus, gateways, …) ──────
# Server-specific integrations ship as separate `ccbot.<name>` subpackages that
# load ONLY when named here (comma-separated). The public tree contains none,
# so this stays empty on a normal deployment; a configured-but-missing package
# is logged and skipped. See src/ccbot/plugins.py for the plugin hook contract.
# The reference deployment runs: drive (rclone mounts: /mount|/umount|/remount,
# Mounts /status section, Fix Drive button) and fleet (preview-server fleet +
# live dashboards) — their env vars below do nothing without the plugin.
# CCBOT_PLUGINS=

# Extra env-var NAMES to strip from os.environ before any agent subprocess
# starts (defense-in-depth for plugin secrets — core already scrubs its own).
# A wamcp/tgmcp deployment sets: CCBOT_SENSITIVE_EXTRA=WAMCP_WEBHOOK_TOKEN,TGMCP_WEBHOOK_TOKEN
# CCBOT_SENSITIVE_EXTRA=

# ── /inject — localhost unix-socket task injection (feature-flagged) ─────
# Off unless the token is set. Lets local automation type a task into an
# agent's pane over a unix socket (no network listener).
# CCBOT_INJECT_TOKEN=
# CCBOT_INJECT_AGENTS=assistant
# CCBOT_INJECT_SOCKET=~/.ccbot/run/inject.sock

# ── preview CLI + Caddy fleet + rclone mounts (plugin-consumed) ──────────
# CCBOT_PREVIEW_BIN / _REGISTRY are the only two core knobs (the worktree
# teardown runs a best-effort `preview down`); everything else here is read
# by the `drive` / `fleet` plugins and inert without them. The domain is
# just an example placeholder.
# CCBOT_PREVIEW_DOMAIN=example.com
# CCBOT_PREVIEW_BIN=~/.local/bin/preview
# CCBOT_PREVIEW_REGISTRY=~/.local/state/preview/registry.json
# CCBOT_CADDY_APPS_DIR=/etc/caddy/apps.d
# CCBOT_RCLONE_MOUNTS=myremote:~/mnt/myremote
